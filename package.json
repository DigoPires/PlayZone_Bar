  "license": "MIT",
  "scripts": {
    "build": "npm run typecheck && npm run build:workspaces",
    "build:workspaces": "npm -r --if-present run build",
    "dev": "node ./scripts/dev.mjs",
    "typecheck:libs": "tsc --build",
    "typecheck": "npm run typecheck:libs && npm -r --prefix artifacts --if-present run typecheck"
  },
  "private": true,
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@replit/connectors-sdk": "^0.4.1",
    "@rollup/rollup-win32-x64-msvc": "^4.62.2",
    "@tailwindcss/oxide-win32-x64-msvc": "^4.3.2",
    "dotenv": "^17.4.2",
    "lightningcss-win32-x64-msvc": "^1.32.0"
  },
  "devDependencies": {
    "prettier": "^3.8.4",
    "typescript": "~5.9.3"
  }
}
