# ============================================================================
# PLAYZONE BAR - ENVIRONMENT VARIABLES TEMPLATE
# ============================================================================
# For production (Render), most of these should be configured via Render
# Settings → Environment. Never commit real credentials to git.

# ============================================================================
# DATABASE - Neon PostgreSQL (for production use Neon "pooler" endpoint)
# ============================================================================
# Format: postgresql://user:password@host:port/dbname?sslmode=require&channel_binding=require
# For Neon pooler: postgresql://user:password@pooler.region.us-east-1.aws.neon.tech/dbname
# For Render: Configure DATABASE_URL in Environment section
DATABASE_URL=postgresql://user:password@localhost:5432/playzone?sslmode=require

# ============================================================================
# API SERVER (Backend)
# ============================================================================
NODE_ENV=development
API_PORT=5000
API_URL=http://localhost:5000
SESSION_SECRET=your-secure-random-session-key-change-in-production

# ============================================================================
# FRONTEND (Vite)
# ============================================================================
PORT=3000
VITE_API_URL=http://localhost:5000

# ============================================================================
# IMAGE STORAGE (Cloudinary)
# ============================================================================
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_UPLOAD_FOLDER=playzone/galeria

# ============================================================================
# CORS & SECURITY
# ============================================================================
CORS_ORIGIN=http://localhost:5173

# ============================================================================
# LOGGING
# ============================================================================
LOG_LEVEL=debug

# ============================================================================
# RENDER DEPLOYMENT (auto-set in production, shown for reference)
# ============================================================================
# RENDER=true
# PORT=10000 (auto-assigned by Render, no need to set)
